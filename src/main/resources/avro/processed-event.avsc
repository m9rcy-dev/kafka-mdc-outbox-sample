        "type": "enum",
        "name": "EventType",
        "symbols": [ "NEW", "UPDATE" ]
      }
    },
    { "name": "name", "type": "string" },
    { "name": "processingStatus", "type": "string" },
    { "name": "processedAt", "type": "string" }
  ]
}
